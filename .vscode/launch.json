{
    "configurations": [
        {
            "name": "Launch Edge",
            "request": "launch",
            "type": "msedge",
            "url": "http://127.0.0.1:3000/docs/index.html",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "firefox",
            "request": "launch",
            "reAttach": true,
            "name": "Launch Firefox",
            "url": "http://127.0.0.1:3000/docs/index.html",
            "webRoot": "${workspaceFolder}/docs"
        },
        {
            "type": "pwa-chrome",
            "name": "Launch Chrome",
            "request": "launch",
            "url": "http://127.0.0.1:3000/docs/index.html"
        }
    ]
}